generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    String  @id @default(uuid())
  email String  @unique
  nome  String?
  senha String
}

model Produto {
  id    String @id @default(uuid())
  nome  String
  preco Float
}
model pedido {
  id          String   @id @default(uuid()) // Se no Supabase for número, mude para: Int @id @default(autoincrement())
  email       String
  nomeCliente String
  valor       Float
  status      String   @default("pendente")
  mp_id       String
  criadoEm    DateTime @default(now())
}